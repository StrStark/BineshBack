# ─────────────────────────────────────────────────────────────────────────────
# Binesh.Api environment template.
# Copy to .env for local dev. NEVER commit a real .env.
#
# In dev: DotNetEnv loads this on startup.
# In prod: set these in your Docker Compose / Kubernetes / systemd unit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
Database__ConnectionString=Host=localhost;Port=5432;Database=binesh;Username=binesh;Password=changeme

# ── JWT signing ──────────────────────────────────────────────────────────────
# Generate a self-signed cert:
#   dotnet dev-certs https --export-path ./certs/binesh-signing.pfx --password <pwd>
Jwt__Issuer=binesh.api
Jwt__Audience=binesh.web
Jwt__SigningCertificatePath=./certs/binesh-signing.pfx
Jwt__SigningCertificatePassword=changeme

# ── OpenAI / OpenAI-compatible endpoint ──────────────────────────────────────
# BaseUrl works for: api.openai.com, api.gapgpt.ir, Azure OpenAI gateways,
# self-hosted vLLM, anything that speaks the OpenAI Chat Completions API.
OpenAI__ApiKey=sk-replace-me
OpenAI__BaseUrl=https://api.openai.com/v1
OpenAI__Model=gpt-4o
OpenAI__FallbackModel=gpt-4o-mini

# ── BI SQL Server source (read-only account recommended) ─────────────────────
# Optional full Data Source override. Use this for named instances such as:
# BI_SQL_DATA_SOURCE=DESKTOP-NAME\INSTANCE
BI_SQL_DATA_SOURCE=
BI_SQL_HOST=host.docker.internal
BI_SQL_PORT=1433
BI_SQL_USERNAME=readonly_user
BI_SQL_PASSWORD=replace-me
BI_SQL_DEFAULT_DATABASE=Anbar
BI_SQL_ANBAR_DATABASE=Anbar
BI_SQL_HESAB_DATABASE=Hesab
BI_SQL_ENCRYPT=true
BI_SQL_TRUST_SERVER_CERTIFICATE=true
BI_SQL_PERSIST_SECURITY_INFO=false
BI_SQL_POOLING=true
BI_SQL_APPLICATION_NAME=Binesh.Api
BI_SQL_COMMAND_TIMEOUT=0

# ── Optional: legacy CONN_STRING the design-time factory reads ───────────────
# Only needed when running 'dotnet ef migrations' without the host loaded.
CONN_STRING=Host=localhost;Port=5432;Database=binesh;Username=binesh;Password=changeme

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
